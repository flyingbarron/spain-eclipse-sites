  <Document>
    <name>Eclipse-Visible IGME Sites</name>
    <description>Geological sites where the 2026 solar eclipse is visible</description>
    
    <!-- Style definitions -->
    <Style id="greenMarker">
      <IconStyle>
        <color>ff00ff00</color>
        <scale>1.2</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/grn-circle.png</href>
        </Icon>
      </IconStyle>
    </Style>
