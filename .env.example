# Environment Variables for Container Deployment
# Copy to .env and customize for your environment

# Server Configuration
ECLIPSE_SITES_SERVER_HOST=0.0.0.0
ECLIPSE_SITES_SERVER_PORT=8000

# Logging
ECLIPSE_SITES_LOGGING_LEVEL=INFO

# Scraping Settings
ECLIPSE_SITES_SCRAPING_REQUEST_TIMEOUT=10
ECLIPSE_SITES_SCRAPING_RATE_LIMIT_DELAY=1.0
ECLIPSE_SITES_SCRAPING_CLOUD_SCRAPE_DELAY=2.0
ECLIPSE_SITES_SCRAPING_HORIZON_SCRAPE_DELAY=2.0

# Feature Flags
ECLIPSE_SITES_FEATURES_ENABLE_CACHING=false
ECLIPSE_SITES_FEATURES_ENABLE_ECLIPSE_CHECKING=true
ECLIPSE_SITES_FEATURES_ENABLE_CLOUD_COVERAGE=true
ECLIPSE_SITES_FEATURES_ENABLE_HORIZON_DOWNLOAD=true